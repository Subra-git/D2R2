<?xml version="1.0" encoding="utf-8"?>

<!-- For more information on using web.config transformation visit http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
	<!--
    In the example below, the "SetAttributes" transform will change the value of 
    "connectionString" to use "ReleaseSQLServer" only when the "Match" locator 
    finds an attribute "name" that has a value of "MyDB".
    
    <connectionStrings>
      <add name="MyDB" 
        connectionString="Data Source=ReleaseSQLServer;Initial Catalog=MyReleaseDB;Integrated Security=True" 
        xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
    </connectionStrings>
  -->
	<connectionStrings xdt:Transform="Remove"/>
	<appSettings>
		<add key="UseSQLDirectly" value="false" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="ApplicationName" value="External Contributors Web Application" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="VersionName" value="Live" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="ShowVersion" value="0" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="ShowReviewEmailPage" value="0" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="EmailFromAddress" value="noreply@apha.gov.uk" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
		<add key="EmailFromDisplayName" value="Surveillance Profiles" xdt:Locator="Match(key)" xdt:Transform="Replace"/>
	</appSettings>

	<system.webServer>
		<security>
			<authentication>
				<windowsAuthentication enabled="false" xdt:Transform="SetAttributes"/>
				<anonymousAuthentication enabled="true" xdt:Transform="SetAttributes"/>
			</authentication>
		</security>
		<defaultDocument xdt:Transform="Remove" />
	</system.webServer>

	<system.web>
		<authentication mode="Forms" xdt:Transform="Remove"/>
		<authentication mode="Forms" xdt:Transform="Insert">
			<forms name=".SsoAuth" loginUrl="../VLAServices/Login.aspx" requireSSL="false" enableCrossAppRedirects="true"/>
		</authentication>
		<authorization xdt:Transform="Remove"/>
		<authorization xdt:Transform="Insert">
			<deny users="?"/>
		</authorization>
		<compilation xdt:Transform="RemoveAttributes(debug)" />
		<!--
      In the example below, the "Replace" transform will replace the entire 
      <customErrors> section of your web.config file.
      Note that because there is only one customErrors section under the 
      <system.web> node, there is no need to use the "xdt:Locator" attribute.
      
      <customErrors defaultRedirect="GenericError.htm"
        mode="RemoteOnly" xdt:Transform="Replace">
        <error statusCode="500" redirect="InternalError.htm"/>
      </customErrors>
    -->
	</system.web>
	<system.serviceModel>
		<client>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/StaticReportService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IStaticReportService" name="StaticReportService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ProfileReportService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IProfileReportService" name="ProfileReportService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/UserAuthenticationService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IUserAuthenticationService" name="UserAuthenticationService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ProfileNoteService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IProfileNoteService" name="ProfileNoteService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ProfileSearchService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IProfileSearchService" name="ProfileSearchService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/SpeciesVersionDataService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.ISpeciesVersionDataService" name="SpeciesVersionDataService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ProfileVersionDataService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IProfileVersionDataService" name="ProfileVersionDataService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ErrorLogService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IErrorLogService" name="ErrorLogService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/SpeciesDataService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.ISpeciesDataService" name="SpeciesDataService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/SpellCheckService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.ISpellCheckService" name="SpellCheckService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ReviewCommentService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IReviewCommentService" name="ReviewCommentService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ReferenceValueService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IReferenceValueService" name="ReferenceValueService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/ProfileQuestionService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IProfileQuestionService" name="ProfileQuestionService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>
			<endpoint behaviorConfiguration="ClientBehaviour" address="http://dawheass01:81/ProfilesServices/PrioritisationService.svc" binding="wsHttpBinding" bindingConfiguration="SsoBinding" contract="Profiles.Contracts.ServiceContracts.IPrioritisationService" name="PrioritisationService" xdt:Transform="SetAttributes" xdt:Locator="Match(contract)"/>

			<endpoint>
				<identity>
					<dns value="DAWHEASS01" xdt:Transform="SetAttributes"/>
				</identity>
			</endpoint>
		</client>
		<behaviors>
			<endpointBehaviors>
				<behavior>
					<clientCredentials xdt:Transform="Insert">
						<serviceCertificate>
							<authentication certificateValidationMode="PeerOrChainTrust" revocationMode="Offline"/>
						</serviceCertificate>
					</clientCredentials>
				</behavior>
			</endpointBehaviors>
		</behaviors>
	</system.serviceModel>
</configuration>